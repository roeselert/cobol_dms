>>SOURCE FORMAT FREE
*> 30STATE0 — documents: file access for the DOCSTAT indexed file
*> (document_status, one row per document). Ops: GET · WRT · REW.
*> L-RET: 00 ok · 23 not found · 22 duplicate · 9x file error.
IDENTIFICATION DIVISION.
PROGRAM-ID. "30STATE0".
ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT STAT-FILE ASSIGN TO "DOCSTAT"
        ORGANIZATION IS INDEXED
        ACCESS MODE IS DYNAMIC
        RECORD KEY IS DS-DOC
        LOCK MODE IS AUTOMATIC
        FILE STATUS IS WS-FS.
DATA DIVISION.
FILE SECTION.
FD STAT-FILE.
COPY "30STATR0.cpy" REPLACING ==:PFX:== BY ==DS==.
WORKING-STORAGE SECTION.
01 WS-FS                PIC X(2).
LINKAGE SECTION.
01 L-OP                 PIC X(4).
01 L-RET                PIC X(2).
COPY "30STATR0.cpy" REPLACING ==:PFX:== BY ==L-DS==.
PROCEDURE DIVISION USING L-OP L-RET L-DS-REC.
MAIN.
    PERFORM OPEN-FILE
    IF L-RET NOT = "00"
        GOBACK
    END-IF
    EVALUATE L-OP
        WHEN "GET " PERFORM DO-GET
        WHEN "WRT " PERFORM DO-WRITE
        WHEN "REW " PERFORM DO-REWRITE
        WHEN OTHER  MOVE "99" TO L-RET
    END-EVALUATE
    CLOSE STAT-FILE
    GOBACK.

OPEN-FILE.
    MOVE "00" TO L-RET
    OPEN I-O STAT-FILE
    IF WS-FS = "35"
        OPEN OUTPUT STAT-FILE
        CLOSE STAT-FILE
        OPEN I-O STAT-FILE
    END-IF
    IF WS-FS NOT = "00" AND WS-FS NOT = "05"
        MOVE "91" TO L-RET
    END-IF.

DO-GET.
    MOVE L-DS-DOC TO DS-DOC
    READ STAT-FILE
    IF WS-FS = "00" OR WS-FS = "02"
        MOVE DS-REC TO L-DS-REC
        MOVE "00" TO L-RET
    ELSE
        MOVE "23" TO L-RET
    END-IF.

DO-WRITE.
    MOVE L-DS-REC TO DS-REC
    WRITE DS-REC
    EVALUATE WS-FS
        WHEN "00" MOVE "00" TO L-RET
        WHEN "02" MOVE "00" TO L-RET
        WHEN "22" MOVE "22" TO L-RET
        WHEN OTHER MOVE "92" TO L-RET
    END-EVALUATE.

DO-REWRITE.
    MOVE L-DS-DOC TO DS-DOC
    READ STAT-FILE
    IF WS-FS NOT = "00" AND WS-FS NOT = "02"
        MOVE "23" TO L-RET
    ELSE
        MOVE L-DS-REC TO DS-REC
        REWRITE DS-REC
        IF WS-FS = "00" OR WS-FS = "02"
            MOVE "00" TO L-RET
        ELSE
            MOVE "92" TO L-RET
        END-IF
    END-IF.
END PROGRAM "30STATE0".
