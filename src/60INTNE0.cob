>>SOURCE FORMAT FREE
*> 60INTNE0 — aiextraction: file access for the EXTRINTENT indexed file
*> (extraction intent catalog). Ops: GET by id · NAME by unique name ·
*> WRT · REW · DEL · ALL (table, sorted by name). L-RET: 00·23·22·9x.
IDENTIFICATION DIVISION.
PROGRAM-ID. "60INTNE0".
ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT INTN-FILE ASSIGN TO "EXTRINTENT"
        ORGANIZATION IS INDEXED
        ACCESS MODE IS DYNAMIC
        RECORD KEY IS IN-ID
        ALTERNATE RECORD KEY IS IN-NAME
        LOCK MODE IS AUTOMATIC
        FILE STATUS IS WS-FS.
DATA DIVISION.
FILE SECTION.
FD INTN-FILE.
COPY "60INTNR0.cpy" REPLACING ==:PFX:== BY ==IN==.
WORKING-STORAGE SECTION.
01 WS-FS                PIC X(2).
LINKAGE SECTION.
01 L-OP                 PIC X(4).
01 L-RET                PIC X(2).
COPY "60INTNR0.cpy" REPLACING ==:PFX:== BY ==L-IN==.
01 L-IN-TABLE.
   05 L-IN-COUNT        PIC 9(4).
   05 L-IN-ROW OCCURS 50.
      10 L-IN-ROW-ID   PIC X(36).
      10 L-IN-ROW-NAME PIC X(100).
      10 L-IN-ROW-DESC PIC X(300).
PROCEDURE DIVISION USING L-OP L-RET L-IN-REC L-IN-TABLE.
MAIN.
    PERFORM OPEN-FILE
    IF L-RET NOT = "00"
        GOBACK
    END-IF
    EVALUATE L-OP
        WHEN "GET " PERFORM DO-GET
        WHEN "NAME" PERFORM DO-BY-NAME
        WHEN "WRT " PERFORM DO-WRITE
        WHEN "REW " PERFORM DO-REWRITE
        WHEN "DEL " PERFORM DO-DELETE
        WHEN "ALL " PERFORM DO-ALL
        WHEN OTHER  MOVE "99" TO L-RET
    END-EVALUATE
    CLOSE INTN-FILE
    GOBACK.

OPEN-FILE.
    MOVE "00" TO L-RET
    OPEN I-O INTN-FILE
    IF WS-FS = "35"
        OPEN OUTPUT INTN-FILE
        CLOSE INTN-FILE
        OPEN I-O INTN-FILE
    END-IF
    IF WS-FS NOT = "00" AND WS-FS NOT = "05"
        MOVE "91" TO L-RET
    END-IF.

DO-GET.
    MOVE L-IN-ID TO IN-ID
    READ INTN-FILE
    IF WS-FS = "00" OR WS-FS = "02"
        MOVE IN-REC TO L-IN-REC
        MOVE "00" TO L-RET
    ELSE
        MOVE "23" TO L-RET
    END-IF.

DO-BY-NAME.
    MOVE L-IN-NAME TO IN-NAME
    READ INTN-FILE KEY IS IN-NAME
    IF WS-FS = "00" OR WS-FS = "02"
        MOVE IN-REC TO L-IN-REC
        MOVE "00" TO L-RET
    ELSE
        MOVE "23" TO L-RET
    END-IF.

DO-WRITE.
    MOVE L-IN-REC TO IN-REC
    WRITE IN-REC
    EVALUATE WS-FS
        WHEN "00" MOVE "00" TO L-RET
        WHEN "02" MOVE "00" TO L-RET
        WHEN "22" MOVE "22" TO L-RET
        WHEN OTHER MOVE "92" TO L-RET
    END-EVALUATE.

DO-REWRITE.
    MOVE L-IN-ID TO IN-ID
    READ INTN-FILE
    IF WS-FS NOT = "00" AND WS-FS NOT = "02"
        MOVE "23" TO L-RET
    ELSE
        MOVE L-IN-REC TO IN-REC
        REWRITE IN-REC
        IF WS-FS = "00" OR WS-FS = "02"
            MOVE "00" TO L-RET
        ELSE
            MOVE "92" TO L-RET
        END-IF
    END-IF.

DO-DELETE.
    MOVE L-IN-ID TO IN-ID
    READ INTN-FILE
    IF WS-FS NOT = "00" AND WS-FS NOT = "02"
        MOVE "23" TO L-RET
    ELSE
        DELETE INTN-FILE
        IF WS-FS = "00"
            MOVE "00" TO L-RET
        ELSE
            MOVE "92" TO L-RET
        END-IF
    END-IF.

DO-ALL.
    MOVE 0 TO L-IN-COUNT
    MOVE LOW-VALUES TO IN-NAME
    START INTN-FILE KEY IS >= IN-NAME
    IF WS-FS = "00"
        PERFORM UNTIL L-IN-COUNT >= 50
            READ INTN-FILE NEXT
            IF WS-FS NOT = "00" AND WS-FS NOT = "02"
                EXIT PERFORM
            END-IF
            ADD 1 TO L-IN-COUNT
            MOVE IN-ID   TO L-IN-ROW-ID (L-IN-COUNT)
            MOVE IN-NAME TO L-IN-ROW-NAME (L-IN-COUNT)
            MOVE IN-DESC TO L-IN-ROW-DESC (L-IN-COUNT)
        END-PERFORM
    END-IF
    MOVE "00" TO L-RET.
END PROGRAM "60INTNE0".
