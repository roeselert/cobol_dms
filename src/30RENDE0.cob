>>SOURCE FORMAT FREE
*> 30RENDE0 — documents: file access for the RENDTION indexed file.
*> Ops: GETD (by unique doc+type) · BYDC (table, all for a document) ·
*> WRT · DEL (by id). L-RET: 00 ok · 23 not found · 22 dup · 9x error.
IDENTIFICATION DIVISION.
PROGRAM-ID. "30RENDE0".
ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT REND-FILE ASSIGN TO "RENDTION"
        ORGANIZATION IS INDEXED
        ACCESS MODE IS DYNAMIC
        RECORD KEY IS RD-ID
        ALTERNATE RECORD KEY IS RD-DOCTYPE
        ALTERNATE RECORD KEY IS RD-DOC WITH DUPLICATES
        LOCK MODE IS AUTOMATIC
        FILE STATUS IS WS-FS.
DATA DIVISION.
FILE SECTION.
FD REND-FILE.
COPY "30RENDR0.cpy" REPLACING ==:PFX:== BY ==RD==.
WORKING-STORAGE SECTION.
01 WS-FS                PIC X(2).
LINKAGE SECTION.
01 L-OP                 PIC X(4).
01 L-RET                PIC X(2).
COPY "30RENDR0.cpy" REPLACING ==:PFX:== BY ==L-RD==.
01 L-RD-TABLE.
   05 L-RD-COUNT        PIC 9(4).
   05 L-RD-ROW OCCURS 10.
      10 L-RD-ROW-TYPE     PIC X(10).
      10 L-RD-ROW-MIME     PIC X(100).
      10 L-RD-ROW-SIZE     PIC 9(13).
      10 L-RD-ROW-SHA256   PIC X(64).
      10 L-RD-ROW-PRODUCER PIC X(15).
PROCEDURE DIVISION USING L-OP L-RET L-RD-REC L-RD-TABLE.
MAIN.
    PERFORM OPEN-FILE
    IF L-RET NOT = "00"
        GOBACK
    END-IF
    EVALUATE L-OP
        WHEN "GETD" PERFORM DO-GET-DOCTYPE
        WHEN "BYDC" PERFORM DO-BY-DOC
        WHEN "WRT " PERFORM DO-WRITE
        WHEN "DEL " PERFORM DO-DELETE
        WHEN OTHER  MOVE "99" TO L-RET
    END-EVALUATE
    CLOSE REND-FILE
    GOBACK.

OPEN-FILE.
    MOVE "00" TO L-RET
    OPEN I-O REND-FILE
    IF WS-FS = "35"
        OPEN OUTPUT REND-FILE
        CLOSE REND-FILE
        OPEN I-O REND-FILE
    END-IF
    IF WS-FS NOT = "00" AND WS-FS NOT = "05"
        MOVE "91" TO L-RET
    END-IF.

DO-GET-DOCTYPE.
    MOVE L-RD-DOCTYPE TO RD-DOCTYPE
    READ REND-FILE KEY IS RD-DOCTYPE
    IF WS-FS = "00" OR WS-FS = "02"
        MOVE RD-REC TO L-RD-REC
        MOVE "00" TO L-RET
    ELSE
        MOVE "23" TO L-RET
    END-IF.

DO-BY-DOC.
    MOVE 0 TO L-RD-COUNT
    MOVE L-RD-DOC TO RD-DOC
    START REND-FILE KEY IS = RD-DOC
    IF WS-FS = "00"
        PERFORM UNTIL L-RD-COUNT >= 10
            READ REND-FILE NEXT
            IF WS-FS NOT = "00" AND WS-FS NOT = "02"
                EXIT PERFORM
            END-IF
            IF RD-DOC NOT = L-RD-DOC
                EXIT PERFORM
            END-IF
            ADD 1 TO L-RD-COUNT
            MOVE RD-TYPE     TO L-RD-ROW-TYPE (L-RD-COUNT)
            MOVE RD-MIME     TO L-RD-ROW-MIME (L-RD-COUNT)
            MOVE RD-SIZE     TO L-RD-ROW-SIZE (L-RD-COUNT)
            MOVE RD-SHA256   TO L-RD-ROW-SHA256 (L-RD-COUNT)
            MOVE RD-PRODUCER TO L-RD-ROW-PRODUCER (L-RD-COUNT)
        END-PERFORM
    END-IF
    MOVE "00" TO L-RET.

DO-WRITE.
    MOVE L-RD-REC TO RD-REC
    WRITE RD-REC
    EVALUATE WS-FS
        WHEN "00" MOVE "00" TO L-RET
        WHEN "02" MOVE "00" TO L-RET
        WHEN "22" MOVE "22" TO L-RET
        WHEN OTHER MOVE "92" TO L-RET
    END-EVALUATE.

DO-DELETE.
    MOVE L-RD-ID TO RD-ID
    READ REND-FILE
    IF WS-FS NOT = "00" AND WS-FS NOT = "02"
        MOVE "23" TO L-RET
    ELSE
        DELETE REND-FILE
        IF WS-FS = "00"
            MOVE "00" TO L-RET
        ELSE
            MOVE "92" TO L-RET
        END-IF
    END-IF.
END PROGRAM "30RENDE0".
